{
  "expo": {
    "name": "yearly",
    "slug": "yearly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "yearly",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/app-icon.png",
      "bundleIdentifier": "com.anonymous.yearly"
    },
    "android": {
      "package": "com.anonymous.yearly",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/app-icon-foreground.png",
        "monochromeImage": "./assets/images/app-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0A",
          "image": "./assets/images/app-icon-foreground.png",
          "imageWidth": 160,
          "android": {
            "image": "./assets/images/app-icon-foreground.png",
            "imageWidth": 160
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
